# Official Weaviate Image
FROM semitechnologies/weaviate:latest

# Default query limit
ENV QUERY_DEFAULTS_LIMIT=25

# Enable anonymous access (for development)
ENV AUTHENTICATION_ANONYMOUS_ACCESS_ENABLED=true

# Data persistence
ENV PERSISTENCE_DATA_PATH=/var/lib/weaviate

# Disable built-in vectorizer since you're using
# SentenceTransformers/OpenAI embeddings
ENV DEFAULT_VECTORIZER_MODULE=none

# Required hostname
ENV CLUSTER_HOSTNAME=WebsiteChunks

EXPOSE 8080